%%{init: {'theme': 'base', 'themeVariables': { 'primaryColor': '#1a1a2e', 'primaryTextColor': '#e0e0e0', 'primaryBorderColor': '#4a9eff', 'lineColor': '#4a9eff', 'secondaryColor': '#16213e', 'tertiaryColor': '#0f3460', 'background': '#0d1117', 'mainBkg': '#1a1a2e', 'nodeBorder': '#4a9eff', 'clusterBkg': '#16213e', 'clusterBorder': '#4a9eff', 'edgeLabelBackground': '#1a1a2e', 'fontFamily': 'Inter, Segoe UI, sans-serif', 'fontSize': '13px' }}}%%
flowchart TD
    START(["<b>START</b>"]) --> INFRA & DAG

    subgraph left ["&nbsp;"]
        direction TB
        INFRA["<b>InfraAgent</b><br/>• MCP: Prometheus<br/>• infra_score<br/>• infra_findings"]
    end

    subgraph middle ["&nbsp;"]
        direction TB
        DAG["<b>DagMapper</b><br/>• Alert → 3GPP procedures<br/>• dags, nf_union"]
    end

    subgraph right ["&nbsp;"]
        direction TB
        M["<b>NfMetricsAgent</b><br/>• MCP: Prometheus<br/>• Per-NF metrics"]
        L["<b>NfLogsAgent</b><br/>• MCP: Loki (+ HTTP fallback)<br/>• Per-NF logs"]
        U["<b>UeTracesAgent</b><br/>• MCP: Loki<br/>• IMSI traces<br/>• Memgraph ingest"]
        EQ["<b>EvidenceQuality</b><br/>• Compute quality score"]
        M --> EQ
        L --> EQ
        U --> EQ
    end

    DAG --> M
    DAG --> L
    DAG --> U

    INFRA --> JR
    EQ --> JR["<b>join_for_rca</b><br/><i>(barrier node)</i><br/>• Writes: compressed_evidence"]
    JR --> RCA["<b>RCAAgent</b><br/><i>Inputs:</i> compressed_evidence<br/><i>Reads:</i> infra_findings, metrics,<br/>logs, UE traces, DAGs from Memgraph<br/><i>Process:</i> LLM analyze → Layer<br/>decision → Root cause"]

    RCA --> RETRY{"should_retry?\n(needs_more_evidence\n+ attempt_count < max)"}
    RETRY -->|"retry"| INC["increment_attempt"]
    INC --> RCA
    RETRY -->|"done"| FIN["<b>Finalize</b>"]
    FIN --> END_NODE(["<b>END</b>"])

    style START fill:#16213e,stroke:#e94560,stroke-width:2px,color:#e0e0e0
    style INFRA fill:#1a1a2e,stroke:#4a9eff,stroke-width:2px,color:#e0e0e0
    style DAG fill:#1a1a2e,stroke:#4a9eff,stroke-width:2px,color:#e0e0e0
    style M fill:#16213e,stroke:#4a9eff,stroke-width:1px,color:#e0e0e0
    style L fill:#16213e,stroke:#4a9eff,stroke-width:1px,color:#e0e0e0
    style U fill:#16213e,stroke:#4a9eff,stroke-width:1px,color:#e0e0e0
    style EQ fill:#16213e,stroke:#4a9eff,stroke-width:1px,color:#e0e0e0
    style JR fill:#16213e,stroke:#4a9eff,stroke-width:2px,color:#e0e0e0
    style RCA fill:#0f3460,stroke:#e94560,stroke-width:2px,color:#e0e0e0
    style RETRY fill:#0f3460,stroke:#ffaa00,stroke-width:1px,color:#e0e0e0
    style INC fill:#16213e,stroke:#ffaa00,stroke-width:1px,color:#e0e0e0
    style FIN fill:#16213e,stroke:#4a9eff,stroke-width:1px,color:#e0e0e0
    style END_NODE fill:#16213e,stroke:#e94560,stroke-width:2px,color:#e0e0e0
    style left fill:#0d1117,stroke:#4a9eff,stroke-width:1px,stroke-dasharray: 5 5,color:#e0e0e0
    style middle fill:#0d1117,stroke:#4a9eff,stroke-width:1px,stroke-dasharray: 5 5,color:#e0e0e0
    style right fill:#0d1117,stroke:#4a9eff,stroke-width:1px,stroke-dasharray: 5 5,color:#e0e0e0
